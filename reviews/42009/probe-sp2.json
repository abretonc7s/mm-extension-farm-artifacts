{
  "title": "probe-sidepanel-perps-mount",
  "validate": {
    "workflow": {
      "pre_conditions": ["wallet.unlocked"],
      "entry": "nav",
      "nodes": {
        "nav": {
          "action": "eval_sync",
          "expression": "(function(){location.hash='#/perps/market/BTC'; return location.hash;})()",
          "save_as": "nav_out",
          "next": "wait"
        },
        "wait": {
          "action": "wait_for",
          "expression": "stateHooks.store.getState().metamask.lastVisitedPerpsRoute !== null",
          "timeout_ms": 8000,
          "next": "probe"
        },
        "probe": {
          "action": "eval_sync",
          "expression": "JSON.stringify({ url: location.href, hash: location.hash, lvpr: stateHooks.store.getState().metamask.lastVisitedPerpsRoute })",
          "save_as": "out",
          "next": "done"
        },
        "done": { "action": "end", "status": "pass" }
      }
    }
  }
}
