        "ac1-assert-order-entry": {
          "action": "eval_sync",
          "expression": "(function(){const all=[...document.querySelectorAll('*')];const available=all.find((el)=>el.textContent?.trim()==='Available to trade');const size=all.find((el)=>el.textContent?.trim()==='Size');const availableRow=available?.parentElement;const balanceText=availableRow?[...availableRow.querySelectorAll('*')].map((el)=>el.textContent?.trim()).find((text)=>Boolean(text)&&/USDC$/.test(text)&&!text.includes('Available to trade')):null;const addFunds=document.querySelector('[data-testid=\"amount-input-add-funds\"]');const probe=document.createElement('div');probe.style.color='var(--color-icon-alternative)';document.body.appendChild(probe);const alternativeColor=getComputedStyle(probe).color;probe.style.color='var(--color-icon-muted)';const mutedColor=getComputedStyle(probe).color;probe.remove();const addFundsColor=addFunds?getComputedStyle(addFunds).color:null;return JSON.stringify({ok:Boolean(available&&size&&balanceText&&addFunds)&&available.getBoundingClientRect().top<size.getBoundingClientRect().top&&!balanceText.includes('$')&&addFundsColor===alternativeColor&&addFundsColor!==mutedColor,balanceText,addFundsColor,alternativeColor,mutedColor,availableTop:available?.getBoundingClientRect().top??null,sizeTop:size?.getBoundingClientRect().top??null})})()",
          "assert": {
            "operator": "eq",
            "field": "ok",
            "value": true
          },
          "next": "ac1-screenshot-order-entry"
        },
