        },
        "ac2-assert-leverage-slider": {
          "action": "eval_sync",
          "expression": "(function(){const sliderHost=document.querySelector('[data-testid=\"leverage-slider\"]');const sliderRoot=sliderHost?.querySelector('.MuiSlider-root');const marks=sliderHost?[...sliderHost.querySelectorAll('.MuiSlider-mark')]:[];const thumb=sliderHost?.querySelector('.MuiSlider-thumb');const labels=[...document.querySelectorAll('*')].filter((el)=>/^\\d+x$/.test(el.textContent?.trim()||''));const sliderBottom=sliderRoot?.getBoundingClientRect().bottom??0;const labelsBelow=labels.filter((el)=>el.getBoundingClientRect().top>=sliderBottom-1);const thumbWidth=thumb?.getBoundingClientRect().width??null;return JSON.stringify({ok:Boolean(sliderHost&&sliderRoot&&thumbWidth!==null)&&marks.length>0&&thumbWidth<=16.5&&labelsBelow.length>=2,marks:marks.length,thumbWidth,labelsBelow:labelsBelow.map((el)=>el.textContent?.trim())})})()",
          "assert": {
            "operator": "eq",
            "field": "ok",
            "value": true
          },
          "next": "ac2-screenshot-leverage-slider"
        },
