          "expression": "(function(){const skip=document.querySelector('[data-testid=\"perps-tutorial-skip-button\"]');const step=document.querySelector('[data-testid=\"perps-tutorial-what-are-perps\"]');const visible=Boolean(step)&&getComputedStyle(step).display!=='none'&&step.getBoundingClientRect().height>0;if(skip&&visible){skip.click();return JSON.stringify({dismissed:true});}return JSON.stringify({dismissed:false});})()",
