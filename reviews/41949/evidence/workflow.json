      },
      "ac11-open-close-position": {
        "action": "press",
        "test_id": "perps-close-cta-button",
        "next": "ac11-wait-close-submit",
        "id": "ac11-open-close-position"
      },
      "ac11-wait-close-submit": {
        "action": "wait_for",
        "test_id": "perps-close-position-modal-submit",
        "timeout_ms": 10000,
        "next": "ac11-assert-close-focused",
        "id": "ac11-wait-close-submit"
      },
      "ac11-assert-close-focused": {
        "action": "eval_sync",
        "expression": "(function(){var button=document.querySelector('[data-testid=\"perps-close-position-modal-submit\"]');return JSON.stringify({focused:document.activeElement===button});})()",
        "assert": {
          "operator": "eq",
          "field": "focused",
          "value": true
        },
        "next": "ac11-screenshot-close-focused",
        "id": "ac11-assert-close-focused"
      },
      "ac11-screenshot-close-focused": {
        "action": "screenshot",
        "filename": "evidence-ac11-close-position-focused.png",
        "note": "AC11: Close position modal opens with the Close Position button focused.",
        "next": "done",
        "id": "ac11-screenshot-close-focused"
      },
      "done": {
        "action": "end",
        "status": "pass",
        "message": "PR 41949 keyboard-first order entry UI validation completed",
        "id": "done"
      }
    }
  }
}