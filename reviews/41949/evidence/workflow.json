        "filename": "evidence-ac10-tpsl-focused.png",
        "note": "AC10: TP/SL modal opens with the TP trigger price input focused.",
        "next": "setup-close-tpsl-modal",
        "id": "ac10-screenshot-tp-focused"
      },
      "setup-close-tpsl-modal": {
        "action": "key_press",
        "key": "Escape",
        "next": "ac11-open-close-position",
