{
  "title": "Review: PR #41802 — keep explore markets live",
  "description": "Validates AC1 (market list page loads with live data), AC6 (Perps tab explore preview renders from usePerpsTabExploreData). AC2/AC3/AC4/AC5 UNTESTABLE.",
  "validate": {
    "workflow": {
      "pre_conditions": ["wallet.unlocked", "perps.feature_enabled"],
      "entry": "setup-navigate-perps-tab",
      "nodes": {
        "setup-navigate-perps-tab": {
          "action": "call",
          "ref": "perps/navigate-perps-tab",
          "next": "ac1-screenshot-perps-tab-entry"
        },
        "ac1-screenshot-perps-tab-entry": {
          "action": "screenshot",
          "filename": "evidence-ac1-perps-tab-entry.png",
          "next": "ac6-check-explore-preview-count"
        },
        "ac6-check-explore-preview-count": {
          "action": "eval_sync",
          "expression": "(function(){ const items = document.querySelectorAll('[data-testid^=\"explore-markets-\"]'); return items.length; })()",
          "assert": {
            "operator": "gt",
            "value": 0
          },
          "next": "ac6-screenshot-perps-tab-explore"
        },
        "ac6-screenshot-perps-tab-explore": {
          "action": "screenshot",
          "filename": "evidence-ac6-perps-tab-explore-preview.png",
          "next": "ac1-navigate-explore-list"
        },
        "ac1-navigate-explore-list": {
          "action": "navigate",
          "target": "PerpsMarketList",
          "next": "ac1-wait-for-market-list"
        },
        "ac1-wait-for-market-list": {
          "action": "wait_for",
          "test_id": "market-list-view",
          "timeout_ms": 8000,
          "next": "ac1-check-market-rows-loaded"
        },
        "ac1-check-market-rows-loaded": {
          "action": "eval_sync",
          "expression": "(function(){ const items = document.querySelectorAll('[data-testid^=\"market-row-\"]'); return items.length; })()",
          "assert": {
            "operator": "gt",
            "value": 0
          },
          "next": "ac1-screenshot-explore-list"
        },
        "ac1-screenshot-explore-list": {
          "action": "screenshot",
          "filename": "evidence-ac1-explore-list-loaded.png",
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
