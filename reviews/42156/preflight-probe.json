          "action": "eval_ref",
          "ref": "accounts",
          "save_as": "accounts",
          "next": "gate-perps-balance"
        },
        "gate-perps-balance": {
          "action": "eval_ref",
          "ref": "perps-balance",
          "save_as": "perps_balance",
          "next": "gate-perps-positions"
        },
        "gate-perps-positions": {
          "action": "eval_ref",
          "ref": "perps-positions",
          "save_as": "perps_positions",
          "next": "gate-perps-markets"
        },
        "gate-perps-markets": {
          "action": "eval_ref",
          "ref": "perps-markets",
          "save_as": "perps_markets",
          "next": "teardown-done"
        },
        "teardown-done": {
          "action": "end",
          "status": "pass",
          "message": "Preflight probes completed"
        }
      }
    }
  }
}
