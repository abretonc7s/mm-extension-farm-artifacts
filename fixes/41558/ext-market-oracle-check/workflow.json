{
  "description": "",
  "hooks": {
    "pre_conditions": [
      "wallet.unlocked"
    ],
    "setup": [],
    "teardown": []
  },
  "inputs": {
    "symbol": {
      "type": "string",
      "default": "ETH",
      "description": "Market symbol"
    }
  },
  "sourcePath": "",
  "title": "Parity snapshot — extension market detail ETH",
  "workflow": {
    "entry": "nav",
    "nodes": {
      "nav": {
        "action": "navigate",
        "target": "PerpsMarketDetails",
        "params": {
          "market": {
            "symbol": "ETH"
          }
        },
        "next": "wait",
        "id": "nav"
      },
      "wait": {
        "action": "wait_for",
        "test_id": "perps-market-detail-page",
        "timeout_ms": 10000,
        "next": "wait-price",
        "id": "wait"
      },
      "extract": {
        "action": "eval_sync",
        "expression": "(function(){\n        function textByTestId(id){ var el=document.querySelector('[data-testid=\"'+id+'\"]'); return el?((el.textContent||'').trim()||null):null; }\n        return JSON.stringify({symbol:'ETH',screen:'market_detail',price:textByTestId('perps-market-detail-price'),change:textByTestId('perps-market-detail-change'),oracle:textByTestId('perps-market-detail-oracle-price')});\n      })()",
        "next": "done",
        "id": "extract"
      },
      "done": {
        "action": "end",
        "status": "pass",
        "id": "done"
      },
      "wait-price": {
        "action": "wait_for",
        "expression": "(function(){var price=(document.querySelector('[data-testid=\\\"perps-market-detail-price\\\"]')?.textContent||'').trim();return JSON.stringify({ready:!!price && !price.includes('---') && price!==''})})()",
        "assert": {
          "operator": "eq",
          "field": "ready",
          "value": true
        },
        "timeout_ms": 10000,
        "poll_ms": 500,
        "next": "extract",
        "id": "wait-price"
      }
    }
  }
}