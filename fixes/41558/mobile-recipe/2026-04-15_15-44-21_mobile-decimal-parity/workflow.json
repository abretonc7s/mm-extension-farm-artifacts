{
  "title": "Mobile perps decimal parity reference",
  "description": "",
  "sourcePath": "/tmp/mobile-decimal-parity.json",
  "hooks": {
    "pre_conditions": [
      "wallet.unlocked",
      "perps.feature_enabled"
    ],
    "setup": [
      {
        "id": "setup-account",
        "action": "call",
        "ref": "perps/select-account",
        "params": {
          "address": "0x8dc623e964475d4d669da601fd15ea9125469003"
        }
      },
      {
        "id": "setup-testnet",
        "action": "call",
        "ref": "perps/setup-testnet"
      },
      {
        "id": "setup-clear-eth",
        "action": "eval_async",
        "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='ETH'});if(!p){return JSON.stringify({cleared:true});}return Engine.context.PerpsController.closePosition({symbol:'ETH'}).then(function(){return JSON.stringify({cleared:true});});})",
        "assert": {
          "operator": "eq",
          "field": "cleared",
          "value": true
        }
      },
      {
        "id": "setup-wait-no-eth",
        "action": "wait_for",
        "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='ETH'});return JSON.stringify({found:!!p});})",
        "assert": {
          "operator": "eq",
          "field": "found",
          "value": false
        },
        "timeout_ms": 10000
      },
      {
        "id": "setup-open-eth",
        "action": "call",
        "ref": "perps/trade-open-market",
        "params": {
          "symbol": "ETH",
          "side": "long",
          "usdAmount": "11",
          "leverage": "2"
        }
      },
      {
        "id": "setup-wait-eth",
        "action": "wait_for",
        "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='ETH'});return JSON.stringify({found:!!p});})",
        "assert": {
          "operator": "eq",
          "field": "found",
          "value": true
        },
        "timeout_ms": 10000
      }
    ],
    "teardown": [
      {
        "id": "teardown-close-eth",
        "action": "eval_async",
        "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='ETH'});if(!p){return JSON.stringify({cleared:true});}return Engine.context.PerpsController.closePosition({symbol:'ETH'}).then(function(){return JSON.stringify({cleared:true});});})",
        "assert": {
          "operator": "eq",
          "field": "cleared",
          "value": true
        }
      }
    ]
  },
  "workflow": {
    "entry": "ac1-home",
    "nodes": {
      "ac1-home": {
        "action": "navigate",
        "target": "PerpsHomeView",
        "next": "ac1-home-wait",
        "id": "ac1-home"
      },
      "ac1-home-wait": {
        "action": "wait_for",
        "route": "PerpsMarketListView",
        "next": "ac1-home-shot",
        "id": "ac1-home-wait"
      },
      "ac1-home-shot": {
        "action": "screenshot",
        "filename": "mobile-01-home.png",
        "next": "ac2-market",
        "id": "ac1-home-shot"
      },
      "ac2-market": {
        "action": "call",
        "ref": "perps/market-discovery",
        "params": {
          "symbol": "ETH"
        },
        "next": "ac2-market-shot",
        "id": "ac2-market"
      },
      "ac2-market-shot": {
        "action": "screenshot",
        "filename": "mobile-02-market-detail.png",
        "next": "ac3-order-press",
        "id": "ac2-market-shot"
      },
      "ac3-order-press": {
        "action": "press",
        "test_id": "perps-market-details-long-button",
        "next": "ac3-order-wait",
        "id": "ac3-order-press"
      },
      "ac3-order-wait": {
        "action": "wait_for",
        "route": "RedesignedConfirmations",
        "next": "ac3-order-shot",
        "id": "ac3-order-wait"
      },
      "ac3-order-shot": {
        "action": "screenshot",
        "filename": "mobile-03-order-entry.png",
        "next": "ac4-market-reset",
        "id": "ac3-order-shot"
      },
      "ac4-market-reset": {
        "action": "navigate",
        "target": "PerpsMarketDetails",
        "params": {
          "market": {
            "symbol": "ETH",
            "name": "ETH",
            "price": "0",
            "change24h": "0",
            "change24hPercent": "0",
            "volume": "0",
            "maxLeverage": "100"
          }
        },
        "next": "ac4-flip-wait",
        "id": "ac4-market-reset"
      },
      "ac4-flip-wait": {
        "action": "wait_for",
        "test_id": "position-card-flip-icon",
        "next": "ac4-flip-press",
        "id": "ac4-flip-wait"
      },
      "ac4-flip-press": {
        "action": "press",
        "test_id": "position-card-flip-icon",
        "next": "ac4-flip-sheet",
        "id": "ac4-flip-press"
      },
      "ac4-flip-sheet": {
        "action": "wait_for",
        "test_id": "perps-flip-position-confirm-sheet",
        "next": "ac4-flip-shot",
        "id": "ac4-flip-sheet"
      },
      "ac4-flip-shot": {
        "action": "screenshot",
        "filename": "mobile-04-flip-sheet.png",
        "next": "ac5-market-reset",
        "id": "ac4-flip-shot"
      },
      "ac5-market-reset": {
        "action": "navigate",
        "target": "PerpsMarketDetails",
        "params": {
          "market": {
            "symbol": "ETH",
            "name": "ETH",
            "price": "0",
            "change24h": "0",
            "change24hPercent": "0",
            "volume": "0",
            "maxLeverage": "100"
          }
        },
        "next": "ac5-margin-wait",
        "id": "ac5-market-reset"
      },
      "ac5-margin-wait": {
        "action": "wait_for",
        "test_id": "position-card-margin-chevron",
        "next": "ac5-margin-press",
        "id": "ac5-margin-wait"
      },
      "ac5-margin-press": {
        "action": "press",
        "test_id": "position-card-margin-chevron",
        "next": "ac5-reduce-wait",
        "id": "ac5-margin-press"
      },
      "ac5-reduce-wait": {
        "action": "wait_for",
        "test_id": "perps-adjust-margin-reduce-btn",
        "next": "ac5-reduce-press",
        "id": "ac5-reduce-wait"
      },
      "ac5-reduce-press": {
        "action": "press",
        "test_id": "perps-adjust-margin-reduce-btn",
        "next": "ac5-adjust-wait",
        "id": "ac5-reduce-press"
      },
      "ac5-adjust-wait": {
        "action": "wait_for",
        "route": "PerpsAdjustMargin",
        "next": "ac5-adjust-shot",
        "id": "ac5-adjust-wait"
      },
      "ac5-adjust-shot": {
        "action": "screenshot",
        "filename": "mobile-05-adjust-margin.png",
        "next": "ac6-market-reset",
        "id": "ac5-adjust-shot"
      },
      "ac6-market-reset": {
        "action": "navigate",
        "target": "PerpsMarketDetails",
        "params": {
          "market": {
            "symbol": "ETH",
            "name": "ETH",
            "price": "0",
            "change24h": "0",
            "change24hPercent": "0",
            "volume": "0",
            "maxLeverage": "100"
          }
        },
        "next": "ac6-close-wait",
        "id": "ac6-market-reset"
      },
      "ac6-close-wait": {
        "action": "wait_for",
        "test_id": "perps-market-details-close-button",
        "next": "ac6-close-press",
        "id": "ac6-close-wait"
      },
      "ac6-close-press": {
        "action": "press",
        "test_id": "perps-market-details-close-button",
        "next": "ac6-close-route",
        "id": "ac6-close-press"
      },
      "ac6-close-route": {
        "action": "wait_for",
        "route": "PerpsClosePosition",
        "next": "ac6-close-shot",
        "id": "ac6-close-route"
      },
      "ac6-close-shot": {
        "action": "screenshot",
        "filename": "mobile-06-close-view.png",
        "next": "done",
        "id": "ac6-close-shot"
      },
      "done": {
        "action": "end",
        "status": "pass",
        "id": "done"
      }
    }
  }
}
