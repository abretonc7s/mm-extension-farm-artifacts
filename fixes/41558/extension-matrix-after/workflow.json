        "save_as": "eth_market",
        "assert": {
          "operator": "not_null",
          "field": "price"
        },
        "next": "eth-check-position",
        "id": "eth-market-data"
      },
      "eth-check-position": {
        "action": "ext_check_dom",
        "test_id": "perps-position-cta-buttons",
        "query": true,
        "save_as": "eth_position_state",
        "next": "eth-position-branch",
        "id": "eth-check-position"
      },
      "eth-position-branch": {
        "action": "switch",
        "cases": [
          {
            "when": {
              "field": "vars.eth_position_state.visible",
              "operator": "truthy"
            },
            "next": "eth-open-modify-menu",
            "index": 0,
            "label": ""
          }
        ],
        "default": "eth-open-order-direct",
        "id": "eth-position-branch"
      },
      "eth-open-modify-menu": {
