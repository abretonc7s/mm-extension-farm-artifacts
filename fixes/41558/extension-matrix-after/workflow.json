{
  "description": "",
  "hooks": {
    "pre_conditions": [
      "wallet.unlocked"
    ],
    "setup": [],
    "teardown": []
  },
  "inputs": {},
  "sourcePath": "",
  "title": "PR #41558 extension decimal matrix",
  "workflow": {
    "entry": "btc-nav-market",
    "nodes": {
      "btc-nav-market": {
        "action": "navigate",
        "target": "PerpsMarketDetails",
        "params": {
          "market": {
            "symbol": "BTC"
          }
        },
        "next": "btc-wait-market",
        "id": "btc-nav-market"
      },
      "btc-wait-market": {
        "action": "wait_for",
        "test_id": "perps-market-detail-page",
        "timeout_ms": 10000,
        "next": "btc-market-data",
        "id": "btc-wait-market"
      },
      "btc-market-data": {
        "action": "eval_sync",
        "expression": "(function(){var price=document.querySelector('[data-testid=\"perps-market-detail-price\"]'); var change=document.querySelector('[data-testid=\"perps-market-detail-change\"]'); return JSON.stringify({symbol:'BTC',screen:'market_detail',price:price?price.textContent.trim():null,change:change?change.textContent.trim():null});})()",
        "save_as": "btc_market",
        "assert": {
          "operator": "not_null",
          "field": "price"
        },
        "next": "btc-open-order",
        "id": "btc-market-data"
      },
      "btc-open-order": {
        "action": "press",
        "test_id": "perps-long-cta-button",
        "next": "btc-wait-order",
        "id": "btc-open-order"
      },
      "btc-wait-order": {
        "action": "wait_for",
        "test_id": "perps-order-entry-page",
        "timeout_ms": 10000,
        "next": "btc-order-data",
        "id": "btc-wait-order"
      },
      "btc-order-data": {
        "action": "eval_sync",
        "expression": "(function(){var price=document.querySelector('[data-testid=\"perps-order-entry-price\"]'); var change=document.querySelector('[data-testid=\"perps-order-entry-change\"]'); return JSON.stringify({symbol:'BTC',screen:'order_entry',price:price?price.textContent.trim():null,change:change?change.textContent.trim():null});})()",
        "save_as": "btc_order",
        "assert": {
          "operator": "not_null",
          "field": "price"
        },
        "next": "eth-nav-market",
        "id": "btc-order-data"
      },
      "eth-nav-market": {
        "action": "navigate",
        "target": "PerpsMarketDetails",
        "params": {
          "market": {
            "symbol": "ETH"
          }
        },
        "next": "eth-wait-market",
        "id": "eth-nav-market"
      },
