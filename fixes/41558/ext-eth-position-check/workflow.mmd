flowchart TD
  %% Parity snapshot — extension ETH position detail
  __entry__(["ENTRY"]) --> node_nav
  node_nav["nav<br/>navigate"]
  node_wait_detail["wait-detail<br/>wait_for"]
  node_check_position["check-position<br/>ext_check_dom"]
  node_branch{"branch<br/>switch"}
  node_open_order["open-order<br/>press"]
  node_wait_order["wait-order<br/>wait_for"]
  node_set_amount["set-amount<br/>set_input"]
  node_submit["submit<br/>press"]
  node_wait_position["wait-position<br/>wait_for"]
  node_extract["extract<br/>eval_sync"]
  node_done(["done<br/>PASS"])
  node_nav --> node_wait_detail
  node_wait_detail --> node_check_position
