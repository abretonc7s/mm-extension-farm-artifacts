{
  "title": "Check Account 6 perps state after switch",
  "validate": {
    "workflow": {
      "pre_conditions": ["wallet.unlocked"],
      "entry": "switch",
      "nodes": {
        "switch": {
          "action": "eval_sync",
          "expression": "(function(){var m=stateHooks.store.getState().metamask;var byId=(m.internalAccounts||{}).accounts||{};var addr='0xb9b9e1c2d011c8edbef8f56b40c1901d1a0742c2';var id=Object.keys(byId).find(function(k){return (byId[k].address||'').toLowerCase()===addr;});stateHooks.submitRequestToBackground('setSelectedAccount',[id]);return JSON.stringify({switched:true});})()",
          "assert": {"all":[{"operator":"eq","field":"switched","value":true}]},
          "save_as": "sw",
          "next": "fetch-state"
        },
        "fetch-state": {
          "action": "eval_async",
          "expression": "(async function(){try{var r=await stateHooks.submitRequestToBackground('perpsGetAccountState',[]);document.title='ACCT6:'+JSON.stringify({bal:r?r.availableBalance:'null',total:r?r.totalBalance:'null',ready:r!==null&&r!==undefined});return JSON.stringify({bal:r?r.availableBalance:'null',total:r?r.totalBalance:'null',ready:r!==null&&r!==undefined});}catch(e){document.title='ACCT6:ERROR:'+e.message;return JSON.stringify({error:e.message,ready:false});}})()",
          "assert": {"all":[{"operator":"neq","field":"error","value":"timeout"}]},
          "save_as": "acct6_state",
          "next": "done"
        },
        "done": {"action":"end","status":"pass"}
      }
    }
  }
}
